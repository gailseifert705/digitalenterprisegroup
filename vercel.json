{
  "rewrites": [
    {
      "source": "/pricing",
      "destination": "/index.html"
    },
    {
      "source": "/pricing/",
      "destination": "/index.html"
    },
    {
      "source": "/pricing/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/services",
      "destination": "/index.html"
    },
    {
      "source": "/automation",
      "destination": "/index.html"
    },
    {
      "source": "/projects",
      "destination": "/index.html"
    },
    {
      "source": "/about",
      "destination": "/index.html"
    },
    {
      "source": "/certificates",
      "destination": "/index.html"
    },
    {
      "source": "/contact",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(favicon.ico|favicon-48x48.png|favicon-512x512.png|apple-touch-icon.png|og-image.jpg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
